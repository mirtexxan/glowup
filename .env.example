# Example environment variables for GlowApp - Costruire e Sorvegliare il Se

# Replicate API key (for image generation and captioning)
REPLICATE_API_KEY=your_replicate_api_key_here

# Unsplash API key (for image search)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Pexels API key (alternative image search)
PEXELS_API_KEY=your_pexels_api_key_here

# OpenAI API key (for prompt unification)
OPENAI_API_KEY=your_openai_api_key_here
